<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIGEE - Sistema de Gestão de Escolas Extintas (SEC/BA)</title>
    
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <script>
        // 1. CONFIGURAÇÃO E CONEXÃO COM O SUPABASE
        const SUPABASE_URL = "https://ckxbvsfjsknbgpfpxcyy.supabase.co";
        const SUPABASE_ANON_KEY = "https://ckxbvsfjsknbgpfpxcyy.supabase.co/rest/v1/"; // <-- COLOQUE SUA CHAVE ANON AQUI

        if (typeof supabase !== 'undefined' && !window.supabase) {
            window.supabase = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        }

        console.log("[SIGEE-Core] Inicializando barramento global de funções...");

        // Variáveis globais para controle de estado
        let usuarioLogado = null;
        let globalProcessos = [];
        let globalUsuarios = [];
        let processofaseFiltroAtivo = "TODOS";

        // Funções auxiliares fictícias para evitar erros de chamada
        async function registrarLog(acao, descricao) {
            try {
                if (typeof supabase !== 'undefined' && window.supabase) {
                    await supabase.from('logs_sistema').insert([{ acao, descricao, usuario_nome: usuarioLogado?.email || 'Sistema' }]);
                }
            } catch (e) { console.error(e); }
        }
        async function carregarEscolasDoSupabase() { console.log("Carregando escolas..."); }
        async function carregarProcessosDoSupabase() { console.log("Carregando processos..."); }
        function filtrarDashboardPorNte() {}
        function filtrarPorBusca() {}
        function mudarPaginaEscola(dir) {}
        function processarImportacaoExcelOtimizada(e) {}
        function abrirFormularioNovaSolicitacao() { document.getElementById('modal-nova-solicitacao-container').classList.remove('hidden'); }
        function fecharFormularioNovaSolicitacao() { document.getElementById('modal-nova-solicitacao-container').classList.add('hidden'); }
        function abrirModalNovaEscola() { alert('Função de cadastro manual de escola.'); }
        function pesquisarEscolaParaProcesso() {}
        function fecharModalEditarProcesso() {}
        function salvarEdicaoDiretaProcesso(e) { e.preventDefault(); }
        function executarForcarFaseMaster(e) { e.preventDefault(); }
        function fecharModalMaster() {}
        function salvarPastaEncontradaTransicao(e) { e.preventDefault(); }
        function fecharModalPastaEncontrada() {}
        function toggleBotaoImpressao() {}
        function processarSaidaAnalisePendencia(e) { e.preventDefault(); }
        function toggleInputTextoPendencia() {}
        function validarFluxoBotaoAnalise() {}
        function atualizarInterfaceEmaileTextoPendencia() {}
        function fecharModalPendencia() {}
        function salvarSaidaPendenciaParaDigitacao(e) { e.preventDefault(); }
        function toggleEstruturaSaidaPendencia() {}
        function renderizarProcessosFlutuantes() {}
        function filtrarProcessosPorEtapa(fase) { processofaseFiltroAtivo = fase; carregarEContarProcessosHorizontais(); }

        // ROTAS E NAVEGAÇÃO INTERNA ENTRE ABAS E SEÇÕES
        window.navegar = function(idTela) {
            console.log("[Navegação] Alterando visualização para a tela:", idTela);
            const secoes = document.querySelectorAll('section, [id^="aba-"], [id^="tela-"], [id^="secao-"]');
            secoes.forEach(s => s.classList.add('hidden'));

            const telaDestino = document.getElementById(idTela) 
                || document.getElementById(`aba-${idTela}`) 
                || document.getElementById(`tela-${idTela}`);
            if (telaDestino) {
                telaDestino.classList.remove('hidden');
            } else {
                console.warn(`[Navegação] O contêiner de destino '${idTela}' não foi localizado no HTML.`);
            }

            if (idTela === 'usuarios') {
                if (typeof window.carregarListaUsuarios === 'function') window.carregarListaUsuarios();
            }
            if (idTela === 'logs') {
                if (typeof window.carregarLogs === 'function') window.carregarLogs();
            }
        };

        // CARREGAR LISTA DE USUÁRIOS DO SUPABASE
        window.carregarListaUsuarios = async function() {
            console.log("[Gestão] Solicitando dados de usuários...");
            const tbody = document.getElementById('tbody-usuarios') || document.getElementById('tabela-usuarios-corpo');
            if (!tbody) return;

            try {
                if (typeof supabase === 'undefined' || !window.supabase) return console.error("Supabase indisponível.");
                const { data: usuarios, error } = await window.supabase
                    .from('usuarios')
                    .select('*')
                    .order('nome', { ascending: true });
                if (error) throw error;
                tbody.innerHTML = "";

                if (!usuarios || usuarios.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center p-4 text-gray-500">Nenhum usuário cadastrado.</td></tr>`;
                    return;
                }

                usuarios.forEach((u) => {
                    const row = document.createElement('tr');
                    row.className = "border-b border-gray-200 hover:bg-gray-50 text-sm";
                    const badgeAtivo = u.ativo 
                        ? `<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold">Ativo</span>`
                        : `<span class="px-2 py-1 bg-red-100 text-red-800 rounded text-xs font-bold">Inativo</span>`;

                    row.innerHTML = `
                        <td class="px-4 py-3 font-semibold text-gray-900">${u.nome || 'Sem Nome'}</td>
                        <td class="px-4 py-3 text-gray-600">${u.perfil || 'Consulta'}</td>
                        <td class="px-4 py-3 text-center text-gray-600 font-medium">${u.nte || 'Todas'}</td>
                        <td class="px-4 py-3 text-center">${badgeAtivo}</td>
                        <td class="px-4 py-3 text-center">
                            <button onclick="window.configurarStatusUsuario('${u.id}', ${u.ativo})" class="px-2 py-1 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded text-xs font-medium border border-gray-300">
                                Alternar Status
                            </button>
                        </td>
                    `;
                    tbody.appendChild(row);
                });
            } catch (err) {
                console.error("Falha no carregamento dos usuários:", err.message);
            }
        };

        // ABRIR MODAL DE CRIAÇÃO DE USUÁRIOS
        window.abrirModalCriarUsuario = function() {
            const modal = document.getElementById('modal-master-controle');
            if (modal) modal.classList.remove('hidden');
        };

        // CARREGAR REGISTROS DE LOGS DO SISTEMA
        window.carregarLogs = async function() {
            const tbody = document.getElementById('tbody-logs') || document.getElementById('tabela-logs-corpo');
            if (!tbody) return;
            try {
                const { data: logs, error } = await window.supabase
                    .from('logs_sistema')
                    .select('*')
                    .order('criado_em', { ascending: false })
                    .limit(50);
                if (error) throw error;
                tbody.innerHTML = "";
                logs.forEach(l => {
                    const row = document.createElement('tr');
                    row.className = "border-b border-gray-100 text-xs text-gray-600";
                    row.innerHTML = `
                        <td class="px-4 py-2 font-mono">${new Date(l.criado_em).toLocaleString('pt-BR')}</td>
                        <td class="px-4 py-2 font-bold text-gray-700">${l.acao}</td>
                        <td class="px-4 py-2">${l.descricao}</td>
                        <td class="px-4 py-2 text-gray-500">${l.usuario_nome || 'Sistema'}</td>
                    `;
                    tbody.appendChild(row);
                });
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center p-4 text-amber-600 bg-amber-50">Auditoria de logs indisponível.</td></tr>`;
            }
        };

        // ALTERNAR STATUS ATIVO/INATIVO DE USUÁRIOS
        window.configurarStatusUsuario = async function(idUsuario, statusAtual) {
            if (usuarioLogado && (usuarioLogado.perfil !== 'Master' && usuarioLogado.perfil !== 'Administrador')) {
                alert("Ação não permitida para o seu nível de acesso.");
                return;
            }
            try {
                const { error } = await window.supabase
                    .from('usuarios')
                    .update({ ativo: !statusAtual })
                    .eq('id', idUsuario);
                if (error) throw error;
                alert("Status atualizado com sucesso!");
                window.carregarListaUsuarios();
            } catch(err) {
                alert(err.message);
            }
        };

        // RENDERIZAR E FILTRAR A TABELA DE PROCESSOS CONFORME REGRA DE ACESSO
        function carregarEContarProcessosHorizontais() {
            const tbody = document.getElementById('tabela-processos-corpo');
            if (!tbody) return;

            let processosFiltrados = globalProcessos;
            if (usuarioLogado && usuarioLogado.perfil !== 'Master' && usuarioLogado.nte) {
                const nteDoUsuario = usuarioLogado.nte.toUpperCase().trim();
                processosFiltrados = processosFiltrados.filter(p => (p.nte || "").toUpperCase().trim() === nteDoUsuario);
            }

            if (processofaseFiltroAtivo && processofaseFiltroAtivo !== "TODOS") {
                processosFiltrados = processosFiltrados.filter(p => {
                    const etapaAtual = (p.etapa || "").toUpperCase().trim();
                    const filtroMapeado = processofaseFiltroAtivo.toUpperCase().trim();
                    return etapaAtual === filtroMapeado;
                });
            }

            tbody.innerHTML = "";
            if (processosFiltrados.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-gray-500">Nenhum processo localizado para os critérios aplicados.</td></tr>`;
                return;
            }

            const fragmento = document.createDocumentFragment();
            processosFiltrados.forEach((p, index) => {
                const row = document.createElement('tr');
                row.className = "border-b border-gray-200 hover:bg-gray-50 text-sm transition-colors";
                
                let badgeClasse = "bg-gray-100 text-gray-800";
                if (p.etapa === 'Análise' || p.etapa === 'Em Análise') badgeClasse = "bg-amber-100 text-amber-800";
                if (p.etapa === 'Finalizado' || p.etapa === 'Deferido') badgeClasse = "bg-green-100 text-green-800";
                if (p.etapa === 'Novo' || p.etapa === 'Desarquivamento') badgeClasse = "bg-blue-100 text-blue-800";

                row.innerHTML = `
                    <td class="px-4 py-3 font-semibold text-gray-900">${p.aluno || "Não Informado"}</td>
                    <td class="px-4 py-3 text-gray-600">${p.escola || "-"}</td>
                    <td class="px-4 py-3 text-center text-gray-600 font-medium">${p.nte || "-"}</td>
                    <td class="px-4 py-3 text-gray-600">${p.documento || "-"}</td>
                    <td class="px-4 py-3 text-center"><span class="px-2 py-1 rounded text-xs font-bold ${badgeClasse}">${p.etapa || "Triagem"}</span></td>
                    <td class="px-4 py-3 text-center">0</td>
                    <td class="px-4 py-3 text-center">
                        <button onclick="alert('Visualizar ID: ' + '${p.id}')" class="px-2 py-1 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 rounded text-xs font-semibold border border-indigo-200 transition-colors">Ver</button>
                    </td>
                `;
                fragmento.appendChild(row);
            });
            tbody.appendChild(fragmento);
        }

        async function carregarUsuariosDoSupabase() {
            console.log("[Cache] Iniciando busca de usuários no Supabase...");
            const { data, error } = await window.supabase.from('usuarios').select('*').order('nome', { ascending: true });
            if (error) {
                console.error("Erro crítico ao carregar lista de usuários:", error.message);
                return;
            }
            globalUsuarios = data || [];
            console.log(`[Cache] Sucesso! ${globalUsuarios.length} usuários armazenados.`);
        }

        async function salvarNovaSolicitacao(event) {
            event.preventDefault();
            const nomeAluno = document.getElementById('proc-nome-aluno').value;
            const documento = document.getElementById('proc-documento').value;
            const nivel = document.getElementById('proc-nivel').value;
            const modalidade = document.getElementById('proc-modalidade').value;
            const nomeEscola = "Escola Não Informada";
            const nteEscola = "NTE 01";

            const novoProcesso = {
                aluno_nome: nomeAluno.toUpperCase(),
                escola_nome: nomeEscola,
                documento_tipo: documento,
                nivel_oferta: nivel,
                modalidade: modalidade,
                etapa_atual: "Desarquivamento",
                dias_decorridos: 0,
                nte: nteEscola
            };

            alert("Abrindo solicitação no banco de dados...");
            const { error } = await window.supabase.from('processos').insert([novoProcesso]);
            if (error) {
                alert("Erro ao criar processo no Supabase: " + error.message);
                return;
            }

            await registrarLog("Criou Processo", `Aluno: ${nomeAluno.toUpperCase()} | Doc: ${documento}`);
            alert("Solicitação salva com sucesso!");
            fecharFormularioNovaSolicitacao();
            await carregarProcessosDoSupabase();
        }

        async function realizarLogin(event) {
            event.preventDefault();
            const campoEmail = document.getElementById('login-email');
            const campoSenha = document.getElementById('login-senha');
            if (!campoEmail || !campoSenha) {
                alert("Erro ao localizar os campos de login no HTML.");
                return;
            }

            const email = campoEmail.value;
            const senha = campoSenha.value;
            if (!email || !senha) {
                alert("Por favor, preencha todos os campos.");
                return;
            }

            alert("Autenticando credenciais...");
            const { data, error } = await window.supabase.auth.signInWithPassword({ email: email, password: senha });
            if (error) {
                alert("Erro ao realizar login: " + error.message);
                return;
            }

            usuarioLogado = data.user;
            registrarLog("Login", "Usuário autenticou com sucesso no sistema.");

            document.getElementById('tela-login').classList.add('hidden');
            document.getElementById('sistema-dashboard').classList.remove('hidden');
            navegar('painel');
        }

        function logout() {
            usuarioLogado = null;
            document.getElementById('sistema-dashboard').classList.add('hidden');
            document.getElementById('tela-login').classList.remove('hidden');
        }

        document.addEventListener("DOMContentLoaded", async () => {
            document.getElementById('tela-login').classList.remove('hidden');
            document.getElementById('sistema-dashboard').classList.add('hidden');

            const formLogin = document.getElementById('form-login');
            if (formLogin) formLogin.addEventListener('submit', realizarLogin);

            if (window.supabase) {
                await carregarEscolasDoSupabase();
                await carregarProcessosDoSupabase();
                await carregarUsuariosDoSupabase();
            }
            carregarEContarProcessosHorizontais();
        });
    </script>
</head>
<body class="bg-gray-100 font-sans text-gray-800 font-normal">

    <div id="tela-login" class="min-h-screen flex items-center justify-center bg-blue-900 px-4">
        <div class="bg-white p-8 rounded-xl shadow-2xl w-full max-w-md">
            <div class="text-center mb-6">
                <span class="bg-amber-500 text-white px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase">SEC / BA</span>
                <h1 class="text-3xl font-extrabold text-blue-900 mt-2">SIGEE</h1>
                <p class="text-gray-500 text-sm mt-1">Gestão de Escolas Extintas e Acervos</p>
            </div>
            <form id="form-login">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">E-mail Corporativo Individual</label>
                    <input type="email" id="login-email" required class="w-full px-4 py-2 border rounded-lg focus:outline-none placeholder:text-gray-400" placeholder="nome.sobrenome@enova.educacao.ba.gov.br">
                </div>
                <div class="mb-6">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Senha</label>
                    <input type="password" id="login-senha" required class="w-full px-4 py-2 border rounded-lg focus:outline-none placeholder:text-gray-400" placeholder="Sua senha">
                </div>
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 rounded-lg shadow-md transition cursor-pointer">Entrar no Sistema</button>
            </form>
        </div>
    </div>

    <div id="sistema-dashboard" class="hidden min-h-screen flex flex-col md:flex-row">
        <aside class="w-full md:w-64 bg-blue-950 text-white flex flex-col shadow-xl">
            <div class="p-5 bg-blue-900 border-b border-blue-800">
                <h2 class="text-2xl font-black tracking-wider text-amber-400">SIGEE</h2>
                <div class="mt-2 text-xs text-blue-200">
                    <p id="user-nome" class="font-bold"></p>
                    <p id="user-perfil" class="italic text-amber-500"></p>
                </div>
            </div>
            <nav class="flex-1 p-4 space-y-2">
                <button onclick="navegar('painel')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📊 Dashboard</button>
                <button onclick="navegar('processos')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📁 Processos (Fluxo)</button>
                <button onclick="navegar('escolas')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">🗄️ Catálogo de Escolas</button>
                <button id="menu-usuarios" onclick="navegar('usuarios')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">👥 Controle de Usuários</button>
                <button id="menu-logs" onclick="navegar('logs')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📜 Aba de Registros (Logs)</button>
            </nav>
            <div class="p-4 border-t border-blue-900">
                <button onclick="logout()" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg text-sm transition cursor-pointer">Sair</button>
            </div>
        </aside>

        <main class="flex-1 p-6 md:p-8 overflow-y-auto">
            <section id="aba-painel" class="space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b pb-4 gap-4">
                    <div><h1 class="text-3xl font-bold text-blue-900">Dashboard de Monitoramento</h1></div>
                    <div>
                        <select id="dash-filtro-nte" onchange="filtrarDashboardPorNte()" class="p-2 border rounded-lg text-sm bg-white font-medium text-gray-700 shadow-sm">
                            <option value="GERAL">📊 VISÃO GERAL (Todos os NTEs)</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                    <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-blue-600"><p class="text-xs text-gray-500 font-medium">Escolas Catalogadas</p><p id="dash-escolas" class="text-2xl font-bold mt-1">0</p></div>
                    <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-emerald-500"><p class="text-xs text-gray-500 font-medium">Acervos Recolhidos</p><p id="dash-acervos" class="text-2xl font-bold mt-1">0</p></div>
                    <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-teal-500"><p class="text-xs text-gray-500 font-medium">Escolas Estaduais</p><p id="dash-estaduais" class="text-2xl font-bold mt-1">0</p></div>
                    <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-indigo-500"><p class="text-xs text-gray-500 font-medium">Total de Municípios</p><p id="dash-municipios" class="text-2xl font-bold mt-1">0</p></div>
                    <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-amber-500"><p class="text-xs text-gray-500 font-medium">Técnicos Cadastrados</p><p id="dash-usuarios" class="text-2xl font-bold mt-1">0</p></div>
                </div>
            </section>

            <section id="aba-processos" class="hidden space-y-6">
                <div class="flex justify-between items-center bg-white p-4 rounded-xl border shadow-xs">
                    <h2 class="text-lg font-bold text-blue-900">Gerenciamento de Fluxos Dinâmicos</h2>
                    <button onclick="abrirFormularioNovaSolicitacao()" class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-4 py-2.5 rounded-lg text-xs shadow-md">➕ 📥 Nova Solicitação</button>
                </div>
                <div class="bg-white rounded-xl border shadow-sm overflow-hidden">
                    <table class="w-full text-left border-collapse text-xs">
                        <thead class="bg-gray-100 font-bold border-b text-gray-600 uppercase">
                            <tr>
                                <th class="p-3">Nome do Aluno</th>
                                <th class="p-3">Escola</th>
                                <th class="p-3">NTE</th>
                                <th class="p-3">Tipo de Documento</th>
                                <th class="p-3">Etapa Atual</th>
                                <th class="p-3">Dias Decorridos</th>
                                <th class="p-3 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-processos-corpo" class="divide-y divide-gray-100"></tbody>
                    </table>
                </div>
            </section>

            <section id="aba-escolas" class="hidden space-y-6">
                <div class="bg-white p-4 rounded-xl border shadow-xs flex flex-wrap items-center justify-between gap-4">
                    <button onclick="abrirModalNovaEscola()" class="bg-blue-900 text-white text-xs font-bold px-4 py-2.5 rounded-lg">➕ Cadastrar Nova Escola</button>
                    <input type="text" id="busca-escola" placeholder="🔎 Digite o termo de busca..." oninput="filtrarPorBusca()" class="w-full p-3 border rounded-lg text-xs bg-gray-50">
                </div>
            </section>

            <section id="aba-usuarios" class="hidden space-y-6">
                <div class="flex justify-between items-center border-b pb-4">
                    <h1 class="text-3xl font-bold text-blue-900">Controle de Usuários e Perfis</h1>
                    <button onclick="abrirModalCriarUsuario()" class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-4 py-2 rounded-lg text-xs">➕ Cadastrar Novo Técnico</button>
                </div>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead class="bg-gray-100 font-semibold border-b">
                            <tr>
                                <th class="p-3">Nome / E-mail</th>
                                <th class="p-3">Perfil</th>
                                <th class="p-3">NTE</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-usuarios-corpo" class="divide-y divide-gray-100"></tbody>
                    </table>
                </div>
            </section>

            <section id="aba-logs" class="hidden space-y-6">
                <h1 class="text-3xl font-bold text-blue-900">Histórico de Atividades</h1>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead class="bg-gray-100 font-semibold border-b">
                            <tr>
                                <th class="p-4">Data/Hora de Registro</th>
                                <th class="p-4">Ação Executada</th>
                                <th class="p-4">Descrição</th>
                                <th class="p-4">Técnico</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-logs-corpo" class="divide-y divide-gray-100 text-gray-700"></tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <div id="modal-nova-solicitacao-container" class="hidden fixed inset-0 bg-blue-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-3xl rounded-xl shadow-2xl border overflow-hidden">
            <div class="bg-blue-900 text-white px-6 py-4 flex justify-between items-center">
                <h2 class="text-base font-bold">📥 Abertura de Solicitação — Desarquivamento</h2>
                <button type="button" onclick="fecharFormularioNovaSolicitacao()" class="text-white font-bold text-sm">✕ Fechar</button>
            </div>
            <form id="form-nova-solicitacao" onsubmit="salvarNovaSolicitacao(event)" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Nome Completo do Aluno</label>
                    <input type="text" id="proc-nome-aluno" required class="w-full p-2 border rounded-lg text-sm">
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Documento Solicitado</label>
                        <select id="proc-documento" required class="w-full p-2 border rounded-lg text-xs bg-gray-50">
                            <option value="">Selecione...</option>
                            <option value="Histórico">Histórico</option>
                            <option value="2ª via">2ª via</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Oferta (Nível)</label>
                        <select id="proc-nivel" required class="w-full p-2 border rounded-lg text-xs bg-gray-50">
                            <option value="">Selecione...</option>
                            <option value="Fundamental">Fundamental</option>
                            <option value="Médio">Médio</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Modalidade</label>
                        <select id="proc-modalidade" required class="w-full p-2 border rounded-lg text-xs bg-gray-50">
                            <option value="">Selecione...</option>
                            <option value="Regular">Regular</option>
                            <option value="Técnico">Técnico</option>
                        </select>
                    </div>
                </div>
                <div class="pt-4 border-t flex justify-end gap-2">
                    <button type="button" onclick="fecharFormularioNovaSolicitacao()" class="px-4 py-2 border rounded-lg text-xs bg-gray-100">Cancelar</button>
                    <button type="submit" class="bg-blue-900 text-white font-bold px-6 py-2.5 rounded-lg text-xs">💾 Abrir Processo</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modal-master-controle" class="hidden fixed inset-0 bg-red-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-xl shadow-2xl overflow-hidden border border-red-200">
            <div class="bg-red-900 text-white px-6 py-4"><h3 class="text-base font-bold">🛠️ Painel Avançado Master</h3></div>
            <div class="p-6 space-y-4">
                <p class="text-sm text-gray-600">Configurações administrativas adicionais para gerenciamento de permissões.</p>
                <div class="flex justify-end pt-2 border-t">
                    <button type="button" onclick="document.getElementById('modal-master-controle').classList.add('hidden')" class="px-4 py-2 border rounded-lg text-xs bg-gray-100">Fechar</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
