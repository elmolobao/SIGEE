<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIGEE - Sistema de Gestão de Escolas Extintas (SEC/BA)</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    
    <script>
        console.log("[SIGEE-Core] Inicializando barramento global de funções...");

        // ==========================================
        // 1. ROTAS E NAVEGAÇÃO INTERNA ENTRE ABAS
        // ==========================================
        window.navegar = function(idTela) {
            console.log("[Navegação] Alterando visualização para a tela:", idTela);
            
            const secoes = document.querySelectorAll('section, [id^="aba-"], [id^="tela-"], [id^="secao-"]');
            secoes.forEach(s => s.classList.add('hidden'));

            const telaDestino = document.getElementById(idTela) 
                || document.getElementById(`aba-${idTela}`) 
                || document.getElementById(`tela-${idTela}`);
                
            if (telaDestino) {
                telaDestino.classList.remove('hidden');
            } else {
                console.warn(`[Navegação] O contêiner de destino '${idTela}' não foi localizado no HTML.`);
            }

            if (idTela === 'usuarios') {
                if (typeof window.carregarListaUsuarios === 'function') window.carregarListaUsuarios();
            }
            if (idTela === 'logs') {
                if (typeof window.carregarLogs === 'function') window.carregarLogs();
            }
        };

        // ==========================================
        // 2. GESTÃO E CARREGAMENTO DE USUÁRIOS
        // ==========================================
        window.carregarListaUsuarios = async function() {
            console.log("[Gestão] Solicitando dados de usuários...");
            const tbody = document.getElementById('tbody-usuarios') || document.getElementById('tabela-usuarios-corpo');
            if (!tbody) return;

            try {
                if (typeof supabase === 'undefined') return console.error("Supabase indisponível.");
                const { data: usuarios, error } = await supabase
                    .from('usuarios')
                    .select('*')
                    .order('nome', { ascending: true });

                if (error) throw error;
                tbody.innerHTML = "";

                if (!usuarios || usuarios.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center p-4 text-gray-500">Nenhum usuário cadastrado.</td></tr>`;
                    return;
                }

                usuarios.forEach((u) => {
                    const row = document.createElement('tr');
                    row.className = "border-b border-gray-200 hover:bg-gray-50 text-sm";
                    const badgeAtivo = u.ativo 
                        ? `<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold">Ativo</span>`
                        : `<span class="px-2 py-1 bg-red-100 text-red-800 rounded text-xs font-bold">Inativo</span>`;

                    row.innerHTML = `
                        <td class="px-4 py-3 font-semibold text-gray-900">${u.nome || 'Sem Nome'}</td>
                        <td class="px-4 py-3 text-gray-600">${u.perfil || 'Consulta'}</td>
                        <td class="px-4 py-3 text-center text-gray-600 font-medium">${u.nte || 'Todas'}</td>
                        <td class="px-4 py-3 text-center">${badgeAtivo}</td>
                        <td class="px-4 py-3 text-center">
                            <button onclick="window.configurarStatusUsuario('${u.id}', ${u.ativo})" class="px-2 py-1 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded text-xs font-medium border border-gray-300">
                                Alternar Status
                            </button>
                        </td>
                    `;
                    tbody.appendChild(row);
                });
            } catch (err) {
                console.error("Falha no carregamento dos usuários:", err.message);
            }
        };

        window.abrirModalCriarUsuario = function() {
            const modal = document.getElementById('modal-master-controle');
            if (modal) modal.classList.remove('hidden');
        };

        window.configurarStatusUsuario = async function(idUsuario, statusAtual) {
            try {
                const { error } = await supabase
                    .from('usuarios')
                    .update({ ativo: !statusAtual })
                    .eq('id', idUsuario);
                if (error) throw error;
                alert("Status atualizado com sucesso!");
                window.carregarListaUsuarios();
            } catch(err) {
                alert(err.message);
            }
        };

        // ==========================================
        // 3. CARREGAR REGISTROS DE LOGS DO SISTEMA
        // ==========================================
        window.carregarLogs = async function() {
            const tbody = document.getElementById('tbody-logs') || document.getElementById('tabela-logs-corpo');
            if (!tbody) return;
            try {
                const { data: logs, error } = await supabase
                    .from('logs_sistema')
                    .select('*')
                    .order('criado_em', { ascending: false })
                    .limit(50);

                if (error) throw error;
                tbody.innerHTML = "";
                logs.forEach(l => {
                    const row = document.createElement('tr');
                    row.className = "border-b border-gray-100 text-xs text-gray-600";
                    row.innerHTML = `
                        <td class="px-4 py-2 font-mono">${new Date(l.criado_em).toLocaleString('pt-BR')}</td>
                        <td class="px-4 py-2 font-bold text-gray-700">${l.usuario_nome || 'Sistema'}</td>
                        <td class="px-4 py-2">${l.acao}</td>
                        <td class="px-4 py-2 text-gray-500">${l.descricao}</td>
                    `;
                    tbody.appendChild(row);
                });
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center p-4 text-amber-600 bg-amber-50">Auditoria de logs indisponível.</td></tr>`;
            }
        };

        // ==========================================
        // 4. FUNÇÕES DE INÍCIO DE EDIÇÃO DE PROCESSO
        // ==========================================
        window.iniciarEdicaoProcesso = async function(idProcesso) {
            console.log(`[Edição] Solicitando dados do processo ID: ${idProcesso}`);
            
            const modal = document.getElementById('modal-editar-processo');
            const inputId = document.getElementById('edit-proc-id');
            const inputNome = document.getElementById('edit-proc-nome');
            const selectDoc = document.getElementById('edit-proc-doc');
            const selectNivel = document.getElementById('edit-proc-nivel');

            if (!modal || !inputId || !inputNome || !selectDoc || !selectNivel) {
                console.error("[Edição] Elementos do modal de edição não foram localizados.");
                return;
            }

            try {
                const { data: processo, error } = await supabase
                    .from('processos')
                    .select('*')
                    .eq('id', idProcesso)
                    .single();

                if (error) throw error;
                if (!processo) throw new Error("Processo não localizado.");

                inputId.value = processo.id;
                inputNome.value = processo.nome_aluno || processo.nome || "";
                selectDoc.value = processo.documento_solicitado || "Histórico";
                selectNivel.value = processo.nivel_oferta || "Médio";

                modal.classList.remove('hidden');
            } catch (err) {
                console.error("[Edição] Erro ao iniciar edição:", err.message);
                alert(`Erro ao carregar dados para edição: ${err.message}`);
            }
        };

        window.fecharModalEditarProcesso = function() {
            const modal = document.getElementById('modal-editar-processo');
            const form = document.getElementById('form-editar-processo-dados');
            if (modal) modal.classList.add('hidden');
            if (form) form.reset();
        };

        window.salvarEdicaoDiretaProcesso = async function(event) {
            event.preventDefault();
            const idProcesso = document.getElementById('edit-proc-id').value;
            const nomeAluno = document.getElementById('edit-proc-nome').value.trim().toUpperCase();
            const docSolicitado = document.getElementById('edit-proc-doc').value;
            const nivelOferta = document.getElementById('edit-proc-nivel').value;

            try {
                const { error } = await supabase
                    .from('processos')
                    .update({
                        nome_aluno: nomeAluno,
                        documento_solicitado: docSolicitado,
                        nivel_oferta: nivelOferta,
                        atualizado_em: new Date().toISOString()
                    })
                    .eq('id', idProcesso);

                if (error) throw error;

                alert("Modificações salvas com sucesso!");
                window.fecharModalEditarProcesso();
                if (typeof window.renderizarProcessosFlutuantes === 'function') window.renderizarProcessosFlutuantes();
            } catch (err) {
                alert(`Erro ao salvar modificações: ${err.message}`);
            }
        };

        // ==========================================
        // 5. FLUXO DE APURAÇÃO (TRAMITAÇÃO DINÂMICA)
        // ==========================================
        window.tramitarProcessoFluxo = async function(idProcesso, etapaAtual) {
            let proximaEtapa = "";

            switch(etapaAtual) {
                case 'Desarquivamento':
                    window.abrirModalPastaEncontrada(idProcesso);
                    return; 
                case 'Análise':
                    proximaEtapa = 'Digitação';
                    break;
                case 'Digitação':
                    proximaEtapa = 'Conferência';
                    break;
                case 'Conferência':
                    proximaEtapa = 'Assinatura';
                    break;
                case 'Assinatura':
                    proximaEtapa = 'Deferido';
                    break;
                default:
                    return;
            }

            if (!confirm(`Deseja evoluir o processo da etapa "${etapaAtual}" para "${proximaEtapa}"?`)) return;

            try {
                const { error } = await supabase
                    .from('processos')
                    .update({
                        etapa_atual: proximaEtapa,
                        atualizado_em: new Date().toISOString()
                    })
                    .eq('id', idProcesso);

                if (error) throw error;
                alert(`Processo avançado para ${proximaEtapa}!`);
                if (typeof window.renderizarProcessosFlutuantes === 'function') window.renderizarProcessosFlutuantes();
            } catch (err) {
                alert(`Erro ao tramitar processo: ${err.message}`);
            }
        };

        window.abrirModalPastaEncontrada = function(idProcesso) {
            const modal = document.getElementById('modal-pasta-encontrada');
            const inputId = document.getElementById('modal-proc-id');
            if (modal && inputId) {
                inputId.value = idProcesso;
                modal.classList.remove('hidden');
            }
        };

        window.fecharModalPastaEncontrada = function() {
            const modal = document.getElementById('modal-pasta-encontrada');
            if (modal) modal.classList.add('hidden');
        };

        window.salvarPastaEncontradaTransicao = async function(event) {
            event.preventDefault();
            const idProcesso = document.getElementById('modal-proc-id').value;
            const tipoArquivo = document.getElementById('modal-proc-tipo-arq').value;
            const localArquivo = document.getElementById('modal-proc-local').value;
            const prioridade = document.getElementById('modal-proc-prioridade').value;

            try {
                const { error } = await supabase
                    .from('processos')
                    .update({
                        tipo_arquivo: tipoArquivo,
                        local_arquivo: localArquivo,
                        prioridade: prioridade,
                        etapa_atual: 'Análise',
                        atualizado_em: new Date().toISOString()
                    })
                    .eq('id', idProcesso);

                if (error) throw error;
                alert("Processo enviado para Análise com sucesso!");
                window.fecharModalPastaEncontrada();
                if (typeof window.renderizarProcessosFlutuantes === 'function') window.renderizarProcessosFlutuantes();
            } catch (err) {
                alert(`Erro ao processar transição: ${err.message}`);
            }
        };

        // ==========================================
        // 6. PAINEL ADVANCED MASTER (FORÇAR FASE)
        // ==========================================
        window.abrirModalMasterControle = function(idProcesso) {
            const modal = document.getElementById('modal-master-controle');
            const inputId = document.getElementById('master-proc-id');
            if (modal && inputId) {
                inputId.value = idProcesso;
                modal.classList.remove('hidden');
            }
        };

        window.fecharModalMaster = function() {
            const modal = document.getElementById('modal-master-controle');
            if (modal) modal.classList.add('hidden');
        };

        window.executarForcarFaseMaster = async function(event) {
            event.preventDefault();
            const idProcesso = document.getElementById('master-proc-id').value;
            const faseAlvo = document.getElementById('master-fase-alvo').value;

            if (!confirm(`Confirma forçar a mudança administrativa para a fase: "${faseAlvo}"?`)) return;

            try {
                const { error } = await supabase
                    .from('processos')
                    .update({
                        etapa_atual: faseAlvo,
                        atualizado_em: new Date().toISOString()
                    })
                    .eq('id', idProcesso);

                if (error) throw error;
                alert(`Sucesso! Processo movido para: ${faseAlvo}`);
                window.fecharModalMaster();
                if (typeof window.renderizarProcessosFlutuantes === 'function') window.renderizarProcessosFlutuantes();
            } catch (err) {
                alert(`Erro crítico Master: ${err.message}`);
            }
        };
    </script>
</head>
<body class="bg-gray-100 font-sans text-gray-800 font-normal">

    <div id="tela-login" class="min-h-screen flex items-center justify-center bg-blue-900 px-4">
        <div class="bg-white p-8 rounded-xl shadow-2xl w-full max-w-md">
            <div class="text-center mb-6">
                <span class="bg-amber-500 text-white px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase">SEC / BA</span>
                <h1 class="text-3xl font-extrabold text-blue-900 mt-2">SIGEE</h1>
                <p class="text-gray-500 text-sm mt-1">Gestão de Escolas Extintas e Acervos</p>
            </div>
            <form id="form-login" onsubmit="handleLogin(event)">
                <div class="mb-4">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">E-mail Corporativo Individual</label>
                    <input type="email" id="login-email" required class="w-full px-4 py-2 border rounded-lg focus:outline-none placeholder:text-gray-400" placeholder="nome.sobrenome@enova.educacao.ba.gov.br">
                </div>
                <div class="mb-6">
                    <label class="block text-gray-700 text-sm font-semibold mb-2">Senha</label>
                    <input type="password" id="login-senha" required class="w-full px-4 py-2 border rounded-lg focus:outline-none placeholder:text-gray-400" placeholder="Sua senha">
                </div>
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 rounded-lg shadow-md transition cursor-pointer">Entrar no Sistema</button>
            </form>
        </div>
    </div>

    <div id="sistema-dashboard" class="hidden min-h-screen flex flex-col md:flex-row">
        <aside class="w-full md:w-64 bg-blue-950 text-white flex flex-col shadow-xl">
            <div class="p-5 bg-blue-900 border-b border-blue-800">
                <h2 class="text-2xl font-black tracking-wider text-amber-400">SIGEE</h2>
                <div class="mt-2 text-xs text-blue-200">
                    <p id="user-nome" class="font-bold"></p>
                    <p id="user-perfil" class="italic text-amber-500"></p>
                </div>
            </div>
            <nav class="flex-1 p-4 space-y-2">
                <button onclick="navegar('painel')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📊 Dashboard</button>
                <button onclick="navegar('processos')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📁 Processos (Fluxo)</button>
                <button onclick="navegar('escolas')" class="w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">🗄️ Catálogo de Escolas</button>
                <button id="menu-usuarios" onclick="navegar('usuarios')" class="hidden w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">👥 Controle de Usuários</button>
                <button id="menu-logs" onclick="navegar('logs')" class="hidden w-full text-left px-4 py-2.5 rounded-lg font-medium hover:bg-blue-800 transition cursor-pointer">📜 Aba de Registros (Logs)</button>
            </nav>
            <div class="p-4 border-t border-blue-900">
                <button onclick="logout()" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg text-sm transition cursor-pointer">Sair</button>
            </div>
        </aside>

        <main class="flex-1 p-6 md:p-8 overflow-y-auto">
            <section id="aba-painel" class="space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b pb-4 gap-4">
                    <div><h1 class="text-3xl font-bold text-blue-900">Dashboard de Monitoramento</h1></div>
                    <div>
                        <select id="dash-filtro-nte" onchange="filtrarDashboardPorNte()" class="p-2 border rounded-lg text-sm bg-white font-medium text-gray-700 shadow-sm">
                            <option value="GERAL">📊 VISÃO GERAL (Todos os NTEs)</option>
                        </select>
                    </div>
                </div>
                
                <div class="space-y-2">
                    <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider">🏢 Informações Gerais</h2>
                    <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
                        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-blue-600"><p class="text-xs text-gray-500 font-medium">Escolas Catalogadas</p><p id="dash-escolas" class="text-2xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-emerald-500"><p class="text-xs text-gray-500 font-medium">Acervos Recolhidos</p><p id="dash-acervos" class="text-2xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-teal-500"><p class="text-xs text-gray-500 font-medium">Escolas Estaduais</p><p id="dash-estaduais" class="text-2xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-indigo-500"><p class="text-xs text-gray-500 font-medium">Total de Municípios</p><p id="dash-municipios" class="text-2xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-amber-500"><p class="text-xs text-gray-500 font-medium">Técnicos Cadastrados</p><p id="dash-usuarios" class="text-2xl font-bold mt-1">0</p></div>
                    </div>
                </div>

                <div class="space-y-2 pt-2">
                    <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider">⚙️ Informações de Processo</h2>
                    <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-gray-400 text-center"><p class="text-xs text-gray-500 font-medium">Desarquivamento</p><p id="dash-proc-desarquivamento" class="text-xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-purple-500 text-center"><p class="text-xs text-gray-500 font-medium">Análise</p><p id="dash-proc-analise" class="text-xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-amber-600 text-center"><p class="text-xs text-gray-500 font-medium">Pendência</p><p id="dash-proc-pendencia" class="text-xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-blue-500 text-center"><p class="text-xs text-gray-500 font-medium">Digitação</p><p id="dash-proc-digitacao" class="text-xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-orange-500 text-center"><p class="text-xs text-gray-500 font-medium">Conferência</p><p id="dash-proc-conferencia" class="text-xl font-bold mt-1">0</p></div>
                        <div class="bg-white p-4 rounded-xl shadow-sm border-t-4 border-emerald-500 text-center"><p class="text-xs text-gray-500 font-medium">Deferido / Assinatura</p><p id="dash-proc-deferido" class="text-xl font-bold mt-1">0</p></div>
                    </div>
                </div>
            </section>

            <section id="aba-processos" class="hidden space-y-6">
                <div class="flex justify-between items-center bg-white p-4 rounded-xl border shadow-xs">
                    <div><h2 class="text-lg font-bold text-blue-900">Gerenciamento de Fluxos Dinâmicos</h2></div>
                    <button onclick="abrirFormularioNovaSolicitacao()" class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-4 py-2.5 rounded-lg text-xs flex items-center gap-1.5 shadow-md cursor-pointer transition">➕ 📥 Nova Solicitação</button>
                </div>

                <div class="bg-white p-4 rounded-xl border shadow-sm space-y-3">
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Selecione uma etapa para filtrar a listagem abaixo:</p>
                    <div class="flex flex-wrap items-center gap-2 w-full">
                        <button onclick="filtrarProcessosPorEtapa('TODOS')" id="btn-fase-todos" class="px-4 py-2.5 bg-blue-900 text-white rounded-lg font-bold text-xs cursor-pointer transition">📋 Todos (<span id="count-horiz-todos">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Desarquivamento')" id="btn-fase-desarquivamento" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">📂 Desarquivamento (<span id="count-horiz-desarquivamento">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Análise')" id="btn-fase-analise" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">🔍 Análise (<span id="count-horiz-analise">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Pendência')" id="btn-fase-pendencia" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">⚠️ Pendência (<span id="count-horiz-pendencia">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Digitação')" id="btn-fase-digitacao" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">⌨️ Digitação (<span id="count-horiz-digitacao">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Conferência')" id="btn-fase-conferencia" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">🧐 Conferência (<span id="count-horiz-conferencia">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Assinatura')" id="btn-fase-assinatura" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">✍️ Assinatura (<span id="count-horiz-assinatura">0</span>)</button>
                        <button onclick="filtrarProcessosPorEtapa('Deferido')" id="btn-fase-deferido" class="px-4 py-2.5 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-lg font-semibold text-xs border cursor-pointer transition">✅ Deferidos (<span id="count-horiz-deferido">0</span>)</button>
                    </div>
                </div>

                <div id="subtopico-processos-lista" class="space-y-4">
                    <div class="bg-white p-3 border rounded-xl shadow-xs flex items-center">
                        <input type="text" id="busca-proc-nome" placeholder="🔍 Pesquisar processos por nome do aluno..." oninput="renderizarProcessosFlutuantes()" class="w-full p-2.5 bg-gray-50 text-xs border rounded-lg focus:outline-none font-medium">
                    </div>
                    
                    <div class="bg-white rounded-xl border shadow-sm overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse text-xs">
                                <thead class="bg-gray-100 font-bold border-b text-gray-600 uppercase">
                                    <tr>
                                        <th class="p-3">Nome do Aluno</th>
                                        <th class="p-3">Escola</th>
                                        <th class="p-3">Tipo de Documento</th>
                                        <th class="p-3">Etapa Atual</th>
                                        <th class="p-3">Dias Decorridos</th>
                                        <th class="p-3">Prazo</th>
                                        <th class="p-3 text-center">Ações de Fluxo</th>
                                    </tr>
                                </thead>
                                <tbody id="tabela-processos-corpo" class="divide-y divide-gray-100"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <section id="aba-escolas" class="hidden space-y-6">
                <div class="bg-white p-4 rounded-xl border shadow-xs flex flex-wrap items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <button onclick="abrirModalNovaEscola()" class="bg-blue-900 text-white text-xs font-bold px-4 py-2.5 rounded-lg shadow-sm hover:bg-blue-950 transition cursor-pointer">➕ Cadastrar Nova Escola</button>
                        <label class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold px-4 py-2.5 rounded-lg shadow-sm cursor-pointer transition">
                            📥 Importar Dados (Excel/CSV)
                            <input type="file" id="input-importar-excel" accept=".xlsx, .xls, .csv" class="hidden" onchange="processarImportacaoExcelOtimizada(event)">
                        </label>
                    </div>
                    <div id="painel-status-importacao" class="hidden flex-1 max-w-md bg-gray-50 border p-2 rounded-lg text-xs space-y-1">
                        <div class="flex justify-between font-bold text-gray-700">
                            <span id="txt-importacao-contador">Importando: 0 / 0</span>
                            <span id="txt-importacao-percentual">0%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2">
                            <div id="barra-importacao-progresso" class="bg-emerald-500 h-2 rounded-full transition-all duration-100" style="width: 0%"></div>
                        </div>
                        <p id="msg-erro-importacao" class="hidden text-red-600 font-semibold truncate"></p>
                    </div>
                </div>

                <div class="bg-white p-3 rounded-xl border shadow-xs">
                    <input type="text" id="busca-escola" placeholder="🔎 Digite o termo de busca para pesquisar no catálogo geral..." oninput="filtrarPorBusca()" class="w-full p-3 border border-gray-300 rounded-lg text-xs bg-gray-50 font-medium focus:outline-none">
                    <div class="mt-1 flex justify-between text-[11px] text-gray-400 font-medium">
                        <span>* O sistema utiliza renderização e paginação dinâmica baseada em buffer para não travar o navegador.</span>
                        <span id="info-quantidade-escolas-carregadas">Exibindo: 0 registros</span>
                    </div>
                </div>

                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse text-[11px]">
                            <thead class="bg-gray-100 font-bold border-b text-gray-600 uppercase">
                                <tr>
                                    <th class="p-3">Nome da Escola</th>
                                    <th class="p-3">Município</th>
                                    <th class="p-3">Dep. Adm / Assinatura</th>
                                    <th class="p-3">Situação Funcional</th>
                                    <th class="p-3">Acervo</th>
                                    <th class="p-3 text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody id="tabela-escolas-corpo" class="divide-y divide-gray-100"></tbody>
                        </table>
                    </div>
                    <div class="p-3 bg-gray-50 border-t flex items-center justify-between text-xs font-semibold">
                        <button onclick="mudarPaginaEscola(-1)" id="btn-escola-anterior" class="px-3 py-1 bg-white border rounded shadow-xs hover:bg-gray-100 disabled:opacity-40">Anterior</button>
                        <span id="txt-escola-paginacao">Página 1</span>
                        <button onclick="mudarPaginaEscola(1)" id="btn-escola-proxima" class="px-3 py-1 bg-white border rounded shadow-xs hover:bg-gray-100 disabled:opacity-40">Próxima</button>
                    </div>
                </div>
            </section>

            <section id="aba-usuarios" class="hidden space-y-6">
                <div class="flex justify-between items-center border-b pb-4">
                    <h1 class="text-3xl font-bold text-blue-900">Controle de Usuários e Perfis</h1>
                    <button onclick="abrirModalCriarUsuario()" class="bg-amber-500 hover:bg-amber-600 text-white font-bold px-4 py-2 rounded-lg text-xs shadow cursor-pointer transition">➕ Cadastrar Novo Técnico</button>
                </div>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead class="bg-gray-100 font-semibold border-b">
                            <tr>
                                <th class="p-3">Nome / E-mail</th>
                                <th class="p-3">Perfil</th>
                                <th class="p-3">NTE</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-usuarios-corpo" class="divide-y divide-gray-100"></tbody>
                    </table>
                </div>
            </section>

            <section id="aba-logs" class="hidden space-y-6">
                <div class="border-b pb-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2">
                    <h1 class="text-3xl font-bold text-blue-900">Histórico de Atividades</h1>
                    <div class="bg-blue-50 border border-blue-200 px-4 py-2 rounded-lg text-xs">
                        <span class="font-bold text-blue-900">Técnico Logado Atual:</span> <span id="log-usuario-corrente" class="font-medium text-gray-700">Nenhum</span>
                    </div>
                </div>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead class="bg-gray-100 font-semibold border-b">
                            <tr>
                                <th class="p-4">Data/Hora de Registro</th>
                                <th class="p-4">Técnico / E-mail</th>
                                <th class="p-4">Ação Executada</th>
                                <th class="p-4">Descrição detalhada</th>
                            </tr>
                        </thead>
                        <tbody id="tabela-logs-corpo" class="divide-y divide-gray-100 text-gray-700"></tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <div id="modal-nova-solicitacao-container" class="hidden fixed inset-0 bg-blue-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50 overflow-y-auto">
        <div class="bg-white w-full max-w-3xl rounded-xl shadow-2xl border overflow-hidden my-8">
            <div class="bg-blue-900 text-white px-6 py-4 flex justify-between items-center">
                <h2 class="text-base font-bold">📥 Abertura de Solicitação — Desarquivamento</h2>
                <button type="button" onclick="fecharFormularioNovaSolicitacao()" class="text-white hover:text-amber-400 font-bold text-sm cursor-pointer">✕ Fechar</button>
            </div>
            <form id="form-nova-solicitacao" onsubmit="salvarNovaSolicitacao(event)" class="p-6 space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Nome Completo do Aluno / Interessado</label>
                    <input type="text" id="proc-nome-aluno" required class="w-full p-2 border rounded-lg text-sm font-medium focus:outline-none">
                </div>

                <div class="bg-blue-50 p-4 rounded-xl border border-blue-200 space-y-3">
                    <label class="block text-xs font-bold text-blue-950 uppercase">Vincular Escola de Origem</label>
                    <div class="relative">
                        <input type="text" id="proc-busca-escola-ref" placeholder="🔎 Digite parte do nome da escola para pesquisar..." oninput="pesquisarEscolaParaProcesso()" class="w-full p-2.5 border rounded-lg text-xs bg-white font-medium focus:outline-none placeholder:text-gray-400">
                        <div id="proc-resultado-busca-escola" class="absolute left-0 right-0 top-full bg-white border rounded-b-lg shadow-lg z-50 max-h-48 overflow-y-auto hidden divide-y"></div>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-5 gap-2 pt-1">
                        <div><label class="block text-[10px] font-bold text-gray-500 uppercase">Cód MEC</label><input type="text" id="auto-cod-mec" readonly class="w-full p-2 bg-gray-100 border text-gray-600 rounded text-xs font-bold"></div>
                        <div><label class="block text-[10px] font-bold text-gray-500 uppercase">Situação Escola</label><input type="text" id="auto-situacao" readonly class="w-full p-2 bg-gray-100 border text-gray-600 rounded text-xs"></div>
                        <div><label class="block text-[10px] font-bold text-gray-500 uppercase">Status Acervo</label><input type="text" id="auto-acervo" readonly class="w-full p-2 bg-gray-100 border text-gray-600 rounded text-xs"></div>
                        <div><label class="block text-[10px] font-bold text-gray-500 uppercase">Local Acervo</label><input type="text" id="auto-local-acervo" readonly class="w-full p-2 bg-gray-100 border text-gray-600 rounded text-xs"></div>
                        <div><label class="block text-[10px] font-bold text-gray-500 uppercase">Assinatura</label><input type="text" id="auto-assinatura" readonly class="w-full p-2 bg-gray-100 border text-gray-600 rounded text-xs"></div>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Documento Solicitado</label>
                        <select id="proc-documento" required class="w-full p-2 border rounded-lg text-xs bg-gray-50 font-medium">
                            <option value="">Selecione...</option><option value="Histórico">Histórico</option><option value="2ª via">2ª via</option><option value="Atestado">Atestado</option><option value="Autenticidade">Autenticidade</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Oferta (Nível)</label>
                        <select id="proc-nivel" required class="w-full p-2 border rounded-lg text-xs bg-gray-50 font-medium">
                            <option value="">Selecione...</option><option value="Fundamental">Fundamental</option><option value="Médio">Médio</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 uppercase mb-1">Modalidade</label>
                        <select id="proc-modalidade" required class="w-full p-2 border rounded-lg text-xs bg-gray-50 font-medium">
                            <option value="">Selecione...</option><option value="Regular">Regular</option><option value="Técnico">Técnico</option><option value="Suplência">Suplência</option>
                        </select>
                    </div>
                </div>
                <div id="container-chk-aluno-acolhido" class="hidden p-3 bg-amber-50 rounded-lg border border-amber-200">
                    <label class="flex items-start gap-2.5 cursor-pointer">
                        <input type="checkbox" id="proc-chk-email-acolhido" class="mt-0.5 h-4 w-4 text-blue-900">
                        <span class="text-xs text-amber-950 font-semibold select-none">Enviar e-mail 01-aluno acolhido (Obrigatório para acervos recolhidos)</span>
                    </label>
                </div>
                <div class="pt-4 border-t flex justify-end gap-2">
                    <button type="button" onclick="fecharFormularioNovaSolicitacao()" class="px-4 py-2 border rounded-lg text-xs font-semibold bg-gray-100 cursor-pointer">Cancelar</button>
                    <button type="submit" class="bg-blue-900 text-white font-bold px-6 py-2.5 rounded-lg text-xs cursor-pointer shadow-md">💾 Abrir Processo</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modal-editar-processo" class="hidden fixed inset-0 bg-blue-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-xl shadow-2xl overflow-hidden border">
            <div class="bg-blue-900 text-white px-6 py-4"><h3 class="text-base font-bold">📝 Editar Dados do Processo</h3></div>
            <form id="form-editar-processo-dados" class="p-6 space-y-4" onsubmit="salvarEdicaoDiretaProcesso(event)">
                <input type="hidden" id="edit-proc-id">
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">Nome Completo do Aluno</label>
                    <input type="text" id="edit-proc-nome" required class="w-full p-2 border rounded-lg text-sm font-semibold uppercase">
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">Documento Solicitado</label>
                    <select id="edit-proc-doc" required class="w-full p-2 border rounded-lg text-sm bg-gray-50">
                        <option value="Histórico">Histórico</option><option value="2ª via">2ª via</option><option value="Atestado">Atestado</option><option value="Autenticidade">Autenticidade</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">Oferta (Nível)</label>
                    <select id="edit-proc-nivel" required class="w-full p-2 border rounded-lg text-sm bg-gray-50">
                        <option value="Fundamental">Fundamental</option><option value="Médio">Médio</option>
                    </select>
                </div>
                <div class="flex justify-end space-x-3 pt-2 border-t">
                    <button type="button" onclick="fecharModalEditarProcesso()" class="px-4 py-2 border rounded-lg text-xs font-semibold bg-gray-100 cursor-pointer">Cancelar</button>
                    <button type="submit" class="px-5 py-2 rounded-lg text-xs font-bold bg-blue-900 text-white shadow">Salvar Modificações</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modal-master-controle" class="hidden fixed inset-0 bg-red-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-xl shadow-2xl overflow-hidden border border-red-200">
            <div class="bg-red-900 text-white px-6 py-4"><h3 class="text-base font-bold">🛠️ Painel Avançado Master (Forçar Etapa)</h3></div>
            <form class="p-6 space-y-4" onsubmit="executarForcarFaseMaster(event)">
                <input type="hidden" id="master-proc-id">
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">Forçar Tramitação para qualquer Fase:</label>
                    <select id="master-fase-alvo" class="w-full p-2.5 border rounded-lg text-sm font-bold bg-gray-50 text-red-950">
                        <option value="Desarquivamento">📂 Desarquivamento</option>
                        <option value="Análise">🔍 Análise</option>
                        <option value="Pendência">⚠️ Pendência</option>
                        <option value="Digitação">⌨️ Digitação</option>
                        <option value="Conferência">🧐 Conferência</option>
                        <option value="Assinatura">✍️ Assinatura</option>
                        <option value="Deferido">✅ Deferido</option>
                    </select>
                </div>
                <div class="p-3 bg-red-50 text-red-900 text-xs rounded-lg border border-red-200 font-medium">
                    * Atenção Administrador: Esta ação ignora travas de e-mails, validações estruturais e regras de NTE.
                </div>
                <div class="flex justify-end space-x-3 pt-2 border-t">
                    <button type="button" onclick="fecharModalMaster()" class="px-4 py-2 border rounded-lg text-xs font-semibold bg-gray-100 cursor-pointer">Cancelar</button>
                    <button type="submit" class="px-5 py-2 rounded-lg text-xs font-bold bg-red-900 text-white shadow">Forçar Update</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modal-pasta-encontrada" class="hidden fixed inset-0 bg-blue-950/60 backdrop-blur-xs flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-xl shadow-2xl overflow-hidden border">
            <div class="bg-purple-900 text-white px-6 py-4"><h3 class="text-base font-bold">📂 Enviar para Análise</h3></div>
            <form id="form-pasta-encontrada" class="p-6 space-y-4" onsubmit="salvarPastaEncontradaTransicao(event)">
                <input type="hidden" id="modal-proc-id">
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">1. Tipo de Arquivo</label>
                    <select id="modal-proc-tipo-arq" required class="w-full p-2 border rounded-lg text-sm bg-gray-50 font-medium">
                        <option value="">-- Selecione --</option>
                        <option value="Pasta">Pasta</option><option value="Ata">Ata</option><option value="Diário">Diário</option><option value="folha de ponto">Folha de Ponto</option><option value="Parecer">Parecer</option><option value="Boletim">Boletim</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">2. Local do Arquivo</label>
                    <select id="modal-proc-local" required class="w-full p-2 border rounded-lg text-sm bg-gray-50 font-medium">
                        <option value="">-- Selecione --</option>
                        <option value="GLPI">GLPI</option><option value="E-DOC">E-DOC</option><option value="NTE">NTE</option><option value="CEE">CEE</option><option value="MP">MP</option><option value="E-mail">E-mail</option><option value="SIGEDUC">SIGEDUC</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-600 mb-1">3. Prioridade</label>
                    <select id="modal-proc-prioridade" required class="w-full p-2 border rounded-lg text-sm bg-gray-50">
                        <option value="Normal">Normal</option><option value="Urgente">Urgente</option><option value="2ª via">2ª via</option><option value="Autenticidade">Autenticidade</option><option value="CEE">CEE</option><option value="MP">MP</option><option value="Ouvidoria">Ouvidoria</option><option value="Exterior">Exterior</option>
                    </select>
                </div>
                <div class="flex justify-end space-x-3 pt-2 border-t">
                    <button type="button" onclick="fecharModalPastaEncontrada()" class="px-4 py-2 border rounded-lg text-xs font-semibold bg-gray-100 cursor-pointer">Cancelar</button>
                    <button type="submit" class="px-5 py-2 rounded-lg text-xs font-bold bg-purple-900 text-white shadow">Confirmar e Tramitar</button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>
